# ─── Contact Form ────────────────────────────────────────────────────────────
# Resend API key — create a free account at https://resend.com
# Verify your domain (treesystems.ai) in the Resend dashboard, then paste the key here.
# Without this key, form submissions are logged to the server console only.
RESEND_API_KEY=re_...

# The email address that receives consultation form submissions.
CONTACT_EMAIL=you@yourdomain.com

# ─── Next.js ─────────────────────────────────────────────────────────────────
# Public base URL — used for absolute links and OG metadata.
# No trailing slash.
NEXT_PUBLIC_SITE_URL=https://treesystems.ai

# NVIDIA NIM API key for the browser chat assistant backend.
# Put the real value in .env or .env.local only; keep this example as a placeholder.
NVIDIA_API_KEY=nvapi_...
